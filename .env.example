# ============================================================
# NEON DATABASE  (https://neon.tech)
# ============================================================

# Pooled connection  ← for app (Vercel serverless)
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# Direct connection  ← for prisma db push / seed only
DIRECT_URL="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"

# ============================================================
# NEXTAUTH  ← must be your Vercel app URL (NOT Neon URL)
# ============================================================
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
